<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Settings</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

<div class="dashboard-container">

    <%- include("partials/sidebar") %>

    <div class="main-content">

        <!-- HEADER -->
        <div class="header premium-header">
            <div>
                <h2>Settings</h2>
                <p class="sub-text">Manage your profile & preferences</p>
            </div>
        </div>

        <!-- PROFILE SECTION -->
        <div class="settings-card">

            <div class="section-header">
                <h2>Profile Details</h2>
                <button class="edit-btn" onclick="enableEdit()">Edit</button>
            </div>

            <div class="settings-grid">

                <div class="field">
                    <label>Company Name</label>
                    <input type="text" id="companyName" disabled>
                </div>

                <div class="field">
                    <label>GST No</label>
                    <input type="text" id="gst" disabled>
                </div>

                <div class="field">
                    <label>Email</label>
                    <input type="text" id="setEmail" disabled>
                </div>

                <div class="field">
                    <label>Phone</label>
                    <input type="text" id="phone" disabled>
                </div>

                <div class="field">
                    <label>Company Address</label>
                    <input type="text" id="address" disabled>
                </div>

            </div>

        </div>

        <!-- PREFERENCES -->
        <div class="settings-card">

            <h3>Preferences</h3>

            <div class="toggle-row">
                <span>Include Company Details in Quotation</span>
                <label class="switch">
                    <input type="checkbox" id="includeCompanyToggle">
                    <span class="slider"></span>
                </label>
            </div>

            <!-- <div class="toggle-row">
                <span>Dark Mode</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle"
                        onchange="toggleDarkMode(this.checked)">
                    <span class="slider"></span>
                </label>
            </div> -->

        </div>

        <!-- ACTION BUTTONS -->
        <div class="settings-actions">
            
            <button class="save-btn" onclick="saveSettings()">Save</button>
        </div>

    </div>

</div>

<script src="/js/settings.js"></script>

</body>
</html>