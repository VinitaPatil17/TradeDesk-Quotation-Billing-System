    };
}
</script> -->

<script>
const isDownload = "<%= isDownload %>" === "true";

if(isDownload){
    window.onload = () => {
        window.print();
    };
}
</script>

<!-- <script src="/js/quotation.js"></script> -->

</body>
</html>