<!DOCTYPE html>
<html>
<head>

<title>Quotation</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/quotation.css"> <!-- reuse same css -->

</head>

<body>

<div class="dashboard-container">

<%- include("partials/sidebar") %>

<div class="main-content">

<div class="top-bar">

<div class="products-section">

<div class="products-header">

    <h3>Quotation List</h3>

    <div class="tools">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search here" oninput="searchQuotations()" id="searchInput" >
    </div>

</div>

<div class="table-container">
<table class="products-table">
<thead>
<tr>
<th>Ledger Name</th>
<th>Phone</th>
<th>Place</th>
<th>Date</th>
<th></th>
</tr>
</thead>

<tbody id="quotationBody">
</tbody>

</table>

<button class="new-product-btn" onclick="openModal()">
+ Create Quotation
</button>
</div>
</div>

</div>
</div>

<div class="modal" id="quotationModal">

<div class="modal-content">

<h3>Create Quotation</h3>

<!-- Ledger -->
<div class="form-group">
<label>Ledger</label>
<select id="ledgerSelect" onchange="fillLedgerDetails()">
<option value="">Select Ledger</option>
</select>
</div>

<div class="form-row">

<div class="form-group">
<label>Phone</label>
<input id="phone" type="text" placeholder="Enter phone">
</div>

<div class="form-group">
<label>City</label>
<input id="place" type="text" placeholder="Enter place">
</div>

<div class="form-group">
<label>State</label>
<input id="state" type="text" placeholder="State">
</div>

<div class="form-group">
<label>GST No</label>
<input id="gst" type="text" placeholder="GST Number">
</div>

</div>

<div class="form-group">
<label>Date</label>
<input id="date" type="date">
</div>

<h4>Products</h4>

<div class="table-wrapper">
<table class="products-table" id="quotationProductsTable">
<thead>
<tr>
<th>Product</th>
<th>Weight</th>
<th>Qty</th>
<th>Price</th>
<th>Total</th>
<th></th>
</tr>
</thead>

<tbody id="quotationProductsBody"></tbody>
</table>
</div>

<div class="btn-group">
<button onclick="openProductModalFromQuotation()" class="new-product-btn">
+ Create Product
</button>

<button onclick="addRow()" class="new-product-btn">
+ Add Row
</button>
</div>

<hr>

<div class="form-row">
<div class="form-group">
<label>Other Charges</label>
<input type="number" id="otherCharges" oninput="calculateGrandTotal()">
</div>

<div class="total-box">
Total: ₹ <span id="grandTotal">0</span>
</div>
</div>

<div class="modal-actions">
<button type="button" class="cancel-btn" onclick="closeModal()">Cancel</button>
<button type="button" class="create-btn" onclick="handleSubmit()">Create</button>
</div>

</div>
</div>

<!-- PRODUCT MODAL (REUSED) -->
<div class="modal" id="productModal">
    <div class="modal-content">
        <h3>Enter Product Details</h3>

        <div class="form-group">
            <label>Product Description</label>
            <input id="desc" type="text" placeholder="Enter product name">
        </div>

        <div class="form-group">
            <label>Weight</label>
            <input id="weight" type="text" placeholder="e.g. 10kg">
        </div>

        <div class="form-group">
            <label>Unit Price</label>
            <input id="price" type="text" placeholder="e.g. ₹500">
        </div>

        <div class="modal-actions">
            <button class="cancel-btn" onclick="closeProductModal()">Cancel</button>
            <button class="save-btn" onclick="saveProductFromQuotation()">Save</button>
        </div>
    </div>
</div>

<script src="/js/quotation.js"></script>

</body>
</html>